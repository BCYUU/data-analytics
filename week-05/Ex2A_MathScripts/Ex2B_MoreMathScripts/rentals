
import math

t = 38 # people
vanCap = 15
vanCost = 250


vanNeed = math.ceil(t/vanCap)
totalCost = vanNeed*vanCost
cpt = totalCost/t # cost per tourist

print(f"vans needed = {vanNeed}")
print(f"cost = ${totalCost}")
print(f"cost per person = ${round(cpt,2)}")

